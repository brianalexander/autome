{
  "compilerOptions": {
    "target": "ES2022",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "strict": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "isolatedModules": true,
    "noEmit": true,
    "baseUrl": ".",
    "types": ["vitest/globals"],
    "paths": {
      "@autome/schemas": ["../src/schemas/pipeline"],
      "@autome/types/*": ["../src/types/*"]
    }
  },
  "include": ["src"]
}
