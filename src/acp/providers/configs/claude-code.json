{
  "name": "claude-code",
  "displayName": "Claude Code",
  "command": "npx",
  "args": ["-y", "@agentclientprotocol/claude-agent-acp@^0.24.2"],
  "agentDirs": {
    "local": ".claude/agents",
    "global": "~/.claude/agents"
  },
  "agentFileExtensions": [".json", ".md"],
  "supportsSessionResume": true,
  "mcpReadinessDelayMs": 5000,
  "sessionCreateTimeoutMs": 60000
}
